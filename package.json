{
  "name": "docker-sentinel",
  "version": "1.0.1",
  "description": "AI-powered Docker log monitoring daemon with Discord, Telegram, and email alerts.",
  "main": "./dist/index.js",
  "bin": {
    "docker-sentinel": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli/index.js start",
    "dev": "tsx src/cli/index.ts start",
    "test": "npm run build && node --test dist/core/*.test.js"
  },
  "keywords": [
    "docker",
    "monitoring",
    "logs",
    "devops",
    "sre",
    "typescript",
    "discord",
    "telegram",
    "gemini-ai"
  ],
  "files": [
    "dist/ai-features/",
    "dist/cli/",
    "dist/config.js",
    "dist/config.d.ts",
    "dist/core/discovery.js",
    "dist/core/docker-events.js",
    "dist/core/docker.js",
    "dist/core/incident-explainer.js",
    "dist/core/incident-manager.js",
    "dist/core/log-collector.js",
    "dist/core/parser.js",
    "dist/core/rules-engine.js",
    "dist/core/watched-containers.js",
    "dist/index.js",
    "dist/notifiers/",
    "dist/types/",
    "dist/utils/",
    "sentinel.config.json",
    "README.md",
    "LICENSE"
  ],
  "author": "Zeh-Eox",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Zeh-Eox/docker-sentinel.git"
  },
  "bugs": {
    "url": "https://github.com/Zeh-Eox/docker-sentinel/issues"
  },
  "homepage": "https://github.com/Zeh-Eox/docker-sentinel#readme",
  "type": "module",
  "dependencies": {
    "axios": "^1.17.0",
    "commander": "^15.0.0",
    "dockerode": "^5.0.0",
    "dotenv": "^17.4.2",
    "inquirer": "^14.0.2",
    "nodemailer": "^9.0.0"
  },
  "devDependencies": {
    "@types/dockerode": "^4.0.1",
    "@types/inquirer": "^9.0.10",
    "@types/node": "^25.9.3",
    "@types/nodemailer": "^8.0.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
